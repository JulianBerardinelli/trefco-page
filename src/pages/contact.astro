---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ContactUs from '~/components/widgets/Contact.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Contacto',
  description: 'Contactá a TREFCO para consultas técnicas o comerciales sobre alambres y cuerdas de cobre y aluminio.',
};
---

<Layout metadata={metadata}>
  <!-- HeroText Widget ******************* -->

  <HeroText tagline="Contacto" title="Hablemos de tu proyecto industrial" />

  <ContactUs
    id="form"
    title="Enviá tu consulta"
    subtitle="Nuestro equipo responde dentro del horario administrativo. También podés llamarnos o escribirnos por mail."
    inputs={[
      {
        type: 'text',
        name: 'name',
        label: 'Nombre y apellido',
      },
      {
        type: 'email',
        name: 'email',
        label: 'Email',
      },
      {
        type: 'text',
        name: 'phone',
        label: 'Teléfono',
      },
    ]}
    textarea={{
      label: 'Mensaje',
    }}
    disclaimer={{
      label: 'Al enviar el formulario, aceptás el tratamiento de tus datos para responder a tu consulta.',
    }}
    description="Horario de administración: 8 hs a 16 hs."
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="Datos de contacto"
    subtitle="TREFCO · Avellaneda, Buenos Aires"
    columns={2}
    items={[
      {
        title: 'Mail',
        description: 'trefco@trefco.com.ar',
        icon: 'tabler:mail',
      },
      {
        title: 'Tel / Cel',
        description: '11 4201 4735 / 11 2649 0109',
        icon: 'tabler:phone',
      },
      {
        title: 'Dirección',
        description: 'Dean Funes 450 / 52, Avellaneda',
        icon: 'tabler:map-pin',
      },
      {
        title: 'Administración',
        description: 'Lunes a viernes, 8 hs a 16 hs',
        icon: 'tabler:clock',
      },
    ]}
  />
</Layout>
