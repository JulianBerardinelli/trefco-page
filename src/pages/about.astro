---
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Steps from '~/components/widgets/Steps.astro';
import Stats from '~/components/widgets/Stats.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'La empresa',
  description: 'TREFCO: industria metalúrgica con más de 25 años produciendo alambres, hilos y cuerdas de cobre y aluminio.',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="Quiénes somos"
    image={{
      src: 'https://images.unsplash.com/photo-1519446330137-dbdca18c5fd1?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=1974&q=80',
      alt: 'Equipo de trabajo industrial',
    }}
  >
    <Fragment slot="title">
      TREFCO: industria metalúrgica en Avellaneda
    </Fragment>

    <Fragment slot="subtitle">
      Emplazados en la provincia de Buenos Aires, ciudad de Avellaneda, somos una industria metalúrgica dedicada a la
      producción de alambres, hilos y cuerdas denudas de metales no ferrosos, cobre y aluminio fundamentalmente. Con una
      trayectoria de más de 25 años de participación en el mercado ligados a la calidad de nuestros productos y a la
      confianza de nuestros clientes y proveedores nos definimos además como una empresa comprometida en el cuidado de
      sus recursos humanos y del medio ambiente.
    </Fragment>
  </Hero>

  <!-- Content Widget **************** -->

  <Content
    isReversed
    title="Una cartera de clientes diversa"
    subtitle="Contamos con clientes en todo el país vinculados a rubros industriales estratégicos."
    items={[
      {
        title: 'Conductores eléctricos y electrónicos',
        description: 'Fabricación de conductores eléctricos y electrónicos para múltiples aplicaciones.',
      },
      {
        title: 'Electrodos y envases metálicos',
        description:
          'Electrodos para soldadura de envases metálicos para conservas de alimentos (legumbres, frutas, etc.).',
      },
      {
        title: 'Industria textil',
        description: 'Alambres de aluminio para cierres y piezas de la industria textil.',
      },
      {
        title: 'Amarres y cercos eléctricos',
        description: 'Alambres de aluminio recocido para amarres, ataduras, cercos eléctricos y boyeros.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'Clientes industriales en Argentina',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Alcance nacional</h3>
      Nuestra producción acompaña procesos críticos de industrias alimenticias, eléctricas y textiles, con atención
      técnica permanente.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-[#140f0c]/60"></div>
    </Fragment>
  </Content>

  <!-- Stats Widget ****************** -->

  <Stats
    title="Nuestra experiencia en números"
    stats={[
      { title: 'Años de trayectoria', amount: '25+' },
      { title: 'Provincia', amount: 'Buenos Aires' },
      { title: 'Metales no ferrosos', amount: '2' },
      { title: 'Mercado', amount: 'Nacional' },
    ]}
  />

  <!-- Steps Widget ****************** -->

  <Steps
    title="Línea de tiempo"
    subtitle="Más de dos décadas de crecimiento sostenido junto a nuestros clientes y proveedores."
    items={[
      {
        title: 'Inicio y consolidación',
        description: 'Comenzamos nuestra actividad con foco en alambres de cobre y aluminio.',
        icon: 'tabler:factory',
      },
      {
        title: 'Expansión productiva',
        description: 'Sumamos nuevas líneas de cuerdas y ampliamos nuestra capacidad industrial.',
        icon: 'tabler:building-factory',
      },
      {
        title: 'Cobertura nacional',
        description: 'Trabajamos con una amplia cartera de clientes en todo el país.',
        icon: 'tabler:map',
      },
      {
        title: 'Calidad y mejora continua',
        description: 'Procesos alineados a normas IRAM y a las exigencias específicas del mercado.',
        icon: 'tabler:certificate',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1504384308090-c894fdcc538d?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=1740&q=80',
      alt: 'Proceso metalúrgico',
    }}
  />

  <!-- Features Widget *************** -->

  <Features
    id="calidad"
    title="Calidad certificada"
    subtitle="Todos nuestros productos son elaborados bajo normas IRAM tanto en sus características dimensionales como físico – mecánicas."
    columns={2}
    items={[
      {
        title: 'Controles dimensionales',
        description: 'Verificación constante de diámetros y tolerancias según especificación.',
        icon: 'tabler:ruler-2',
      },
      {
        title: 'Propiedades físico-mecánicas',
        description: 'Aseguramos resistencia, ductilidad y conductividad de acuerdo a norma.',
        icon: 'tabler:chart-dots-3',
      },
      {
        title: 'Producción adaptable',
        description: 'Ajustamos parámetros de exigencia y calidad según requerimientos del cliente.',
        icon: 'tabler:settings',
      },
      {
        title: 'Compromiso ambiental',
        description: 'Procesos responsables con el entorno y el cuidado de los recursos humanos.',
        icon: 'tabler:leaf',
      },
    ]}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    id="mision-vision"
    title="Misión, visión y valores"
    subtitle="Sostenemos una cultura industrial orientada a la calidad y la confianza."
    columns={3}
    items={[
      {
        title: 'Misión',
        description:
          'Producir alambres, hilos y cuerdas de metales no ferrosos con calidad IRAM y respuesta técnica confiable.',
        icon: 'tabler:target',
      },
      {
        title: 'Visión',
        description:
          'Ser un referente nacional en soluciones metalúrgicas de cobre y aluminio, con innovación continua.',
        icon: 'tabler:eye',
      },
      {
        title: 'Valores',
        description: 'Calidad, compromiso humano, responsabilidad ambiental y relaciones de largo plazo.',
        icon: 'tabler:heart-handshake',
      },
    ]}
  />
</Layout>
