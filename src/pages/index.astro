---
import Layout from '~/layouts/PageLayout.astro';

import Hero2 from '~/components/widgets/Hero2.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';
import Steps from '~/components/widgets/Steps.astro';
import Stats from '~/components/widgets/Stats.astro';
import Features2 from '~/components/widgets/Features2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Steps2 from '~/components/widgets/Steps2.astro';

const metadata = {
  title: 'Industria metalúrgica en Avellaneda',
  description:
    'Alambres, hilos y cuerdas de cobre y aluminio con más de 25 años de trayectoria y producción bajo normas IRAM.',
};
---

<Layout metadata={metadata}>
  <!-- Hero2 Widget ******************* -->

  <Hero2
    tagline="Industria metalúrgica · Avellaneda, Buenos Aires"
    actions={[
      { variant: 'primary', text: 'Ver productos', href: '/productos' },
      { variant: 'secondary', text: 'Contactanos', href: '/contact' },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1504328345606-18bbc8c9d7d1?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'Producción metalúrgica en planta',
    }}
  >
    <Fragment slot="title">
      TREFCO: alambres, hilos y cuerdas <br />
      de <span class="text-accent dark:text-white">cobre y aluminio</span>
    </Fragment>

    <Fragment slot="subtitle">
      Más de 25 años acompañando a la industria argentina con soluciones en metales no ferrosos, calidad IRAM y una
      producción adaptable a los requerimientos técnicos de cada cliente.
    </Fragment>
  </Hero2>

  <!-- Stats Widget ****************** -->

  <Stats
    stats={[
      { title: 'Trayectoria', amount: '25+ años' },
      { title: 'Normas', amount: 'IRAM' },
      { title: 'Cobertura', amount: 'Todo el país' },
      { title: 'Especialidad', amount: 'Cobre + Aluminio' },
    ]}
  />

  <!-- Features Widget *************** -->

  <Features
    id="features"
    title="Producción confiable para industrias exigentes"
    subtitle="Fabricamos alambres, hilos y cuerdas con estándares dimensionales y físico-mecánicos controlados."
    columns={2}
    items={[
      {
        title: 'Alambres de cobre reciclado',
        description: 'Diámetros desde Ø 0.30 mm hasta Ø 5.00 mm con trazabilidad y consistencia.',
        icon: 'tabler:recycle',
      },
      {
        title: 'Cobre electrolítico',
        description: 'Alambres redondos desde Ø 0.20 mm hasta Ø 1.80 mm para usos eléctricos y electrónicos.',
        icon: 'tabler:bolt',
      },
      {
        title: 'Aluminio puro y aleado',
        description: 'Producción desde Ø 0.50 mm hasta Ø 5.20 mm para aplicaciones técnicas y estructurales.',
        icon: 'tabler:layers-union',
      },
      {
        title: 'Cuerdas en 7 hilos',
        description: 'Cobre Ø 10 mm² a Ø 50 mm² y aluminio Ø 16 mm² a Ø 50 mm².',
        icon: 'tabler:brand-databricks',
      },
      {
        title: 'Calidad bajo normas IRAM',
        description: 'Procesos alineados con estándares dimensionales y físico-mecánicos certificados.',
        icon: 'tabler:badge-check',
      },
      {
        title: 'Producción adaptable',
        description: 'Ajustamos parámetros de exigencia y calidad según el proyecto del cliente.',
        icon: 'tabler:adjustments',
      },
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    isReversed
    tagline="La empresa"
    title="Industria metalúrgica con foco humano y ambiental"
    items={[
      {
        title: 'Compromiso integral',
        description:
          'Nos definimos como una empresa comprometida en el cuidado de nuestros recursos humanos y del medio ambiente, con una trayectoria sólida en el mercado.',
      },
      {
        title: 'Clientes en todo el país',
        description:
          'Acompañamos a empresas de diversos rubros industriales, con entregas constantes y asesoramiento técnico.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1496247749665-49cf5b1022e9?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=1974&q=80',
      alt: 'Equipo industrial en planta',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">
        Más de 25 años de participación en el mercado
      </h3>
      Calidad, confianza y relaciones sostenibles con clientes y proveedores.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-[#140f0c]/60"></div>
    </Fragment>
  </Content>

  <!-- Steps Widget ****************** -->

  <Steps
    title="Nuestra trayectoria en hitos"
    subtitle="El crecimiento de TREFCO se construye con constancia, inversión en procesos y escucha activa del mercado."
    items={[
      {
        title: 'Más de 25 años de experiencia',
        description: 'Consolidamos la producción de alambres y cuerdas no ferrosas para el mercado nacional.',
        icon: 'tabler:timeline',
      },
      {
        title: 'Relaciones de confianza',
        description: 'Clientes y proveedores nos acompañan por la calidad sostenida y la respuesta técnica.',
        icon: 'tabler:heart-handshake',
      },
      {
        title: 'Capacidad industrial flexible',
        description: 'Ajustamos parámetros de producción según normas y exigencias particulares.',
        icon: 'tabler:settings-2',
      },
      {
        title: 'Compromiso con las personas',
        description: 'Cuidamos nuestros recursos humanos y el entorno en cada etapa del proceso.',
        icon: 'tabler:leaf',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1489515217757-5fd1be406fef?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'Linea de producción metalúrgica',
    }}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="Misión, visión y valores"
    subtitle="Trabajamos con foco en calidad, eficiencia y mejora continua."
    columns={3}
    items={[
      {
        title: 'Misión',
        description:
          'Producir alambres, hilos y cuerdas no ferrosas con estándares IRAM, adaptándonos a las necesidades técnicas de cada cliente.',
        icon: 'tabler:target',
      },
      {
        title: 'Visión',
        description:
          'Consolidarnos como un referente nacional en soluciones metalúrgicas de cobre y aluminio, con procesos responsables.',
        icon: 'tabler:binoculars',
      },
      {
        title: 'Valores',
        description: 'Calidad, seguridad, respeto por las personas, compromiso ambiental y confianza comercial.',
        icon: 'tabler:shield-check',
      },
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    isAfterContent={true}
    title="Aplicaciones industriales"
    subtitle="Nuestros productos abastecen múltiples sectores productivos en todo el país."
    items={[
      {
        title: 'Conductores eléctricos y electrónicos',
        description: 'Alambres de cobre con alta conductividad para cables y componentes.',
      },
      {
        title: 'Electrodos y envases metálicos',
        description: 'Soluciones para soldadura de envases de conservas y procesos de electrodo.',
      },
      {
        title: 'Industria textil',
        description: 'Alambres de aluminio para cierres y usos auxiliares.',
      },
      {
        title: 'Amarres, ataduras y cercos eléctricos',
        description: 'Aluminio recocido para amarres, boyeros y aplicaciones rurales.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1503387762-592deb58ef4e?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'Aplicaciones industriales de metales',
    }}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Conocer productos',
        href: '/productos',
      },
      {
        variant: 'secondary',
        text: 'Solicitar asesoramiento',
        href: '/contact',
      },
    ]}
  >
    <Fragment slot="title">
      Productos certificados, listos para tu industria
    </Fragment>

    <Fragment slot="subtitle">
      Conocé las especificaciones de cobre y aluminio disponibles y pedinos una propuesta a medida.
    </Fragment>
  </CallToAction>

  <!-- Steps2 Widget ****************** -->

  <Steps2
    title="Contacto directo"
    subtitle="Estamos disponibles para consultas técnicas y comerciales."
    callToAction={{
      text: 'Ver contacto completo',
      href: '/contact',
    }}
    items={[
      {
        title: 'Mail',
        description: 'trefco@trefco.com.ar',
        icon: 'tabler:mail',
      },
      {
        title: 'Tel / Cel',
        description: '11 4201 4735 / 11 2649 0109',
        icon: 'tabler:phone',
      },
      {
        title: 'Administración',
        description: 'Lunes a viernes, 8 hs a 16 hs',
        icon: 'tabler:clock',
      },
    ]}
  />
</Layout>
